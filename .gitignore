.gitignore
# --------------------------------------------------
# Python: bytecode y caché
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# --------------------------------------------------
# Entornos virtuales
# --------------------------------------------------
.venv/
venv/
env/
ENV/

# --------------------------------------------------
# Variables de entorno y secretos
# --------------------------------------------------
.env
.env.*
!.env.example

# --------------------------------------------------
# Tests, cobertura y herramientas de calidad
# --------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

.mypy_cache/
.ruff_cache/
.pyright/
.tox/
.nox/

# --------------------------------------------------
# Empaquetado y compilación
# --------------------------------------------------
build/
dist/
*.egg-info/
.eggs/
wheels/

# --------------------------------------------------
# Archivos generados por el proyecto
# --------------------------------------------------
output/

# --------------------------------------------------
# Editores e IDE
# --------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# --------------------------------------------------
# Sistema operativo
# --------------------------------------------------
.DS_Store
Thumbs.db

# --------------------------------------------------
# Logs y archivos temporales
# --------------------------------------------------
*.log
*.tmp
*.temp

Refactoring.md 
QualityImprovement.md
Planning.md